# Application
FIOS_ENVIRONMENT=development
FIOS_DEBUG=false
FIOS_DOCS_ENABLED=true
FIOS_HOST=0.0.0.0
FIOS_PORT=8000

# Logging
FIOS_LOG_LEVEL=INFO
FIOS_LOG_JSON=false

# Database (either a full URL or discrete parts)
# FIOS_DATABASE_URL=postgresql+asyncpg://fios:fios@localhost:5432/fios
FIOS_POSTGRES_HOST=localhost
FIOS_POSTGRES_PORT=5432
FIOS_POSTGRES_USER=fios
FIOS_POSTGRES_PASSWORD=fios
FIOS_POSTGRES_DB=fios
FIOS_DB_POOL_SIZE=10
FIOS_DB_MAX_OVERFLOW=20
FIOS_DB_POOL_TIMEOUT=30
FIOS_DB_POOL_RECYCLE=1800
FIOS_DB_ECHO=false

# Redis (either a full URL or discrete parts)
# FIOS_REDIS_URL=redis://localhost:6379/0
FIOS_REDIS_HOST=localhost
FIOS_REDIS_PORT=6379
FIOS_REDIS_DB=0
# FIOS_REDIS_PASSWORD=

# Auth / JWT
FIOS_JWT_ALGORITHM=HS256
FIOS_JWT_SECRET_KEY=local-dev-only-secret-change-me
# For RS256 provide PEM key paths instead of a secret:
# FIOS_JWT_PRIVATE_KEY_PATH=/run/secrets/jwt_private.pem
# FIOS_JWT_PUBLIC_KEY_PATH=/run/secrets/jwt_public.pem
FIOS_JWT_ISSUER=fios
FIOS_JWT_AUDIENCE=fios-api
FIOS_ACCESS_TOKEN_TTL_SECONDS=900
FIOS_REFRESH_TOKEN_TTL_SECONDS=2592000

# CORS (comma-separated origins)
FIOS_CORS_ORIGINS=http://localhost:3000

# Rate limiting
FIOS_RATE_LIMIT_ENABLED=true
FIOS_RATE_LIMIT_REQUESTS=120
FIOS_RATE_LIMIT_WINDOW_SECONDS=60

# Request validation
FIOS_MAX_REQUEST_BODY_BYTES=10485760

# OpenTelemetry
FIOS_OTEL_ENABLED=false
# FIOS_OTEL_EXPORTER_ENDPOINT=http://localhost:4318
FIOS_OTEL_SERVICE_NAME=fios-api

# Seed data (admin created by `python -m app.cli seed run` when both are set)
FIOS_SEED_ADMIN_EMAIL=admin@fios.com
FIOS_SEED_ADMIN_PASSWORD=admin-fios-local

# LLM providers (AI council chat + loan analysis).
# Gemini is preferred when both are set; Groq is the fallback. When neither is
# set, /chat returns 503 and loan analysis falls back to the rule-based engine.
# FIOS_GEMINI_API_KEY=
FIOS_GEMINI_MODEL=gemini-2.0-flash
# FIOS_GROQ_API_KEY=
FIOS_GROQ_MODEL=llama-3.3-70b-versatile
FIOS_LLM_TIMEOUT_SECONDS=45

# Document uploads
FIOS_UPLOAD_DIR=uploads
FIOS_MAX_UPLOAD_BYTES=15728640
